@inherits LayoutComponentBase
@inject ApiClient ApiClient
@inject NavigationManager Navigation

<MudLayout>

    <MudAppBar Color="Color.Primary" Fixed="@fixedAppBar" Dense="@dense" Elevation="@elevation">

        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />

        <MudText Typo="Typo.h6" Class="ml-3">Training System</MudText>

        <MudSpacer />

        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body1" Class="mr-4">Welcome, @context.User.Identity?.Name</MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Inherit" OnClick="Logout" Size="Size.Small">
                    Logout
                </MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Href="/login" Size="Size.Small">
                    Login
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Width="240px" Elevation="@elevation" ClipMode="DrawerClipMode.Docked">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private int elevation = 1;
    private bool dense = true;
    private bool fixedAppBar = true;
    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task Logout()
    {
        await ApiClient.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}