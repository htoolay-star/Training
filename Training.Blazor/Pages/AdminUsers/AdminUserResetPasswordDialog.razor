@using Training.Blazor.Services.AdminUser
@inject IAdminUserApiClient AdminUserApi
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudText Class="mb-6">Reset password for <strong>@UserName</strong></MudText>

        <MudForm @ref="_form">
            <MudTextField @bind-Value="password" Label="New Password" InputType="InputType.Password"
                          Required="true" RequiredError="Password is required" Class="mb-4" />

            <MudTextField @bind-Value="confirmPassword" Label="Confirm Password" InputType="InputType.Password"
                          Required="true" RequiredError="Please confirm the password" Class="mb-4" />

            <div class="d-flex justify-end mt-4">
                <MudButton OnClick="Cancel" Class="me-2">Cancel</MudButton>
                <MudButton OnClick="SaveAsync" Variant="Variant.Filled" Color="Color.Warning" Disabled="@isSaving">
                    @(isSaving ? "Resetting..." : "Reset Password")
                </MudButton>
            </div>
        </MudForm>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public long UserId { get; set; }
    [Parameter] public string UserName { get; set; } = "";

    private string password = "";
    private string confirmPassword = "";
    private bool isSaving = false;
    private MudForm _form = default!;

    private async Task SaveAsync()
    {
        isSaving = true;

        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            isSaving = false;
            return;
        }

        if (password != confirmPassword)
        {
            Snackbar.Add("Passwords do not match.", Severity.Error);
            isSaving = false;
            return;
        }

        if (password.Length < 8)
        {
            Snackbar.Add("Password must be at least 8 characters.", Severity.Error);
            isSaving = false;
            return;
        }

        try
        {
            var request = new ResetPasswordRequest { Id = UserId, NewPassword = password };
            var result = await AdminUserApi.ResetPasswordAsync(request);
            if (result is { IsSuccess: true })
            {
                Snackbar.Add("Password reset successfully.", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add(result?.Message ?? "Failed to reset password.", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("An unexpected error occurred.", Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
