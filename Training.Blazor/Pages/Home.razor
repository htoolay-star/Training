@page "/"
@inject NavigationManager Navigation

<PageTitle>Home - Training System</PageTitle>

<MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-6 fw-bold">
    Administration Dashboard
</MudText>

<MudGrid>
    <MudItem xs="12" sm="6">
        <MudPaper Elevation="3" Class="pa-8 d-flex flex-column align-center text-center"
                  Style="cursor: pointer; border-radius: 8px;"
                  @onclick="@(() => Navigation.NavigateTo("/roles"))">
            <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Large" Color="Color.Primary" Class="mb-4" />
            <MudText Typo="Typo.h5" Class="mb-2 fw-bold">Role Management</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Create, edit, and manage system roles and their properties.
            </MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="6">
        <MudPaper Elevation="3" Class="pa-8 d-flex flex-column align-center text-center"
                  Style="cursor: pointer; border-radius: 8px;"
                  @onclick="@(() => Navigation.NavigateTo("/admin-users"))">
            <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Primary" Class="mb-4" />
            <MudText Typo="Typo.h5" Class="mb-2 fw-bold">Admin Users</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Manage admin users, assign roles, and reset passwords.
            </MudText>
        </MudPaper>
    </MudItem>
</MudGrid>
